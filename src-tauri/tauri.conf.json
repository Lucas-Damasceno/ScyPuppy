{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ScryPuppy",
  "version": "1.0.0-beta.11",
  "identifier": "com.scryppy.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "create": false,
        "title": "ScryPuppy",
        "width": 1100,
        "height": 720,
        "minWidth": 920,
        "minHeight": 560
      },
      {
        "create": false,
        "label": "paste",
        "title": "Colar com ScryPuppy",
        "url": "index.html",
        "width": 480,
        "height": 560,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false
      },
      {
        "create": false,
        "label": "quick-context",
        "title": "Quick context",
        "url": "index.html",
        "width": 384,
        "height": 320,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "focus": false
      },
      {
        "create": false,
        "label": "magic-search",
        "title": "Buscar com ScryPuppy",
        "url": "index.html",
        "width": 720,
        "height": 560,
        "minWidth": 620,
        "minHeight": 480,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "maximizable": false,
        "minimizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/installer-hooks.nsh",
        "languages": ["English", "PortugueseBR"],
        "customLanguageFiles": {
          "English": "./windows/languages/English.nsh",
          "PortugueseBR": "./windows/languages/PortugueseBR.nsh"
        },
        "displayLanguageSelector": true
      },
      "wix": {
        "language": ["en-US", "pt-BR"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYyOTQ4N0I0QTg0NTdFM0MKUldROGZrV290SWVVWWpGS0ExYkQ1bCtjNEd5aVhQUm5Zb1JOZjBsTDB3WllkMjI4TjFOMVFaQ1YK",
      "endpoints": [
        "https://github.com/Lucas-Damasceno/ScryPuppy/releases/download/updater-beta/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
